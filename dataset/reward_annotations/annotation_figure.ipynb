    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"15nc0vrlrj9\",\n",
    "   \"source\": \"|## Boxplot — reward별로 묶기, 각 게임 분포 비교\",\n",
    "   \"metadata\": {}\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"0b2f8reifrgw\",\n",
    "   \"source\": \"## Lineplot — reward별로 묶기, 게임별 KDE 분포 (같은 reward는 y-scale 통일)\",\n",
    "   \"metadata\": {}\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-04-02T06:20:15.460987Z\",\n",
    "     \"start_time\": \"2026-04-02T06:20:15.087846Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"from matplotlib.transforms import blended_transform_factory\\n\",\n",
    "    \"\\n\",\n",
    "    \"GAME_COLORS = {\\n\",\n",
    "    \"    \\\"dungeon\\\": \\\"#4C72B0\\\",\\n\",\n",
    "    \"    \\\"doom\\\":    \\\"#DD8452\\\",\\n\",\n",
    "    \"    \\\"zelda\\\":   \\\"#55A868\\\",\\n\",\n",
    "    \"    \\\"pokemon\\\": \\\"#C44E52\\\",\\n\",\n",
    "    \"    \\\"sokoban\\\": \\\"#8172B2\\\",\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _is_empty(vals):\\n\",\n",
    "    \"    \\\"\\\"\\\"데이터 없음 또는 모두 0인 경우 True.\\\"\\\"\\\"\\n\",\n",
    "    \"    return len(vals) == 0 or (vals == 0).all()\\n\",\n",
    "    \"\\n\",\n",
    "    \"n_rewards = len(REWARDS)\\n\",\n",
    "    \"fig, axes = plt.subplots(1, n_rewards, figsize=(4.5 * n_rewards, 5))\\n\",\n",
    "    \"fig.suptitle(\\\"Reward Condition Distribution by Game (Boxplot)\\\", fontsize=16, fontweight=\\\"bold\\\", y=1.02)\\n\",\n",
    "    \"\\n\",\n",
    "    \"for ax, (r_enum, feat, cond_col) in zip(axes, REWARDS):\\n\",\n",
    "    \"    sub = all_df[all_df[\\\"feature_name\\\"] == feat]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    valid_positions, valid_data, valid_colors = [], [], []\\n\",\n",
    "    \"    na_positions = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for idx, game in enumerate(GAMES, start=1):\\n\",\n",
    "    \"        vals = pd.to_numeric(\\n\",\n",
    "    \"            sub[sub[\\\"game\\\"] == game][cond_col], errors=\\\"coerce\\\"\\n\",\n",
    "    \"        ).dropna().values\\n\",\n",
    "    \"        if _is_empty(vals):\\n\",\n",
    "    \"            na_positions.append(idx)\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            valid_positions.append(idx)\\n\",\n",
    "    \"            valid_data.append(vals)\\n\",\n",
    "    \"            valid_colors.append(GAME_COLORS[game])\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if valid_data:\\n\",\n",
    "    \"        bp = ax.boxplot(\\n\",\n",
    "    \"            valid_data,\\n\",\n",
    "    \"            positions=valid_positions,\\n\",\n",
    "    \"            patch_artist=True,\\n\",\n",
    "    \"            medianprops=dict(color=\\\"black\\\", linewidth=1.5),\\n\",\n",
    "    \"            whiskerprops=dict(linewidth=1.2),\\n\",\n",
    "    \"            capprops=dict(linewidth=1.2),\\n\",\n",
    "    \"            flierprops=dict(marker=\\\"o\\\", markersize=2, alpha=0.3),\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"        for patch, color in zip(bp[\\\"boxes\\\"], valid_colors):\\n\",\n",
    "    \"            patch.set_facecolor(color)\\n\",\n",
    "    \"            patch.set_alpha(0.8)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # N/A 텍스트: x는 데이터 좌표, y는 axes 하단 고정\\n\",\n",
    "    \"    trans = blended_transform_factory(ax.transData, ax.transAxes)\\n\",\n",
    "    \"    for idx in na_positions:\\n\",\n",
    "    \"        ax.text(idx, 0.02, \\\"N/A\\\", ha=\\\"center\\\", va=\\\"bottom\\\",\\n\",\n",
    "    \"                transform=trans, color=\\\"gray\\\", fontsize=8)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    ax.set_xticks(range(1, len(GAMES) + 1))\\n\",\n",
    "    \"    ax.set_xticklabels(GAMES, rotation=30, ha=\\\"right\\\", fontsize=9)\\n\",\n",
    "    \"    ax.set_xlim(0.5, len(GAMES) + 0.5)\\n\",\n",
    "    \"    ax.set_title(f\\\"R{r_enum}: {feat}\\\", fontsize=10, fontweight=\\\"bold\\\")\\n\",\n",
    "    \"    ax.set_ylabel(cond_col, fontsize=8)\\n\",\n",
    "    \"    ax.grid(axis=\\\"y\\\", linestyle=\\\"--\\\", alpha=0.5)\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"#plt.savefig(\\\"boxplot_rewards.png\\\", dpi=150, bbox_inches=\\\"tight\\\")\\n\",\n",
    "    \"plt.show()\"\n",
    "   ],\n",
