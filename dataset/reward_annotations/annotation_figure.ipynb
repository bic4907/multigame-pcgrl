    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# ── Percentile Threshold 분석 ────────────────────────────────────────────────\\n# 각 게임 × task(feature)에 대해 25/50/75 percentile을 n.5 형식으로 변환하고\\n# 그 threshold 기준으로 4구간에 데이터가 얼마나 분포하는지 비율로 확인한다.\\n#\\n# n.5 규칙: threshold = floor(raw_percentile) + 0.5\\n#   → 정수 tile count가 threshold에 걸쳐 쪼개지지 않고 한 구간에 모인다.\\n\\nimport numpy as np\\nimport pandas as pd\\n\\ndef to_n5(v):\\n    \\\"\\\"\\\"float → n.5 형식 (floor + 0.5).\\\"\\\"\\\"\\n    return float(np.floor(v) + 0.5)\\n\\nrows = []\\nfor game in GAMES:\\n    for r_enum, feat, cond_col in REWARDS:\\n        sub = all_df[(all_df[\\\"game\\\"] == game) & (all_df[\\\"feature_name\\\"] == feat)]\\n        vals = pd.to_numeric(sub[cond_col], errors=\\\"coerce\\\").dropna().values\\n        if len(vals) == 0 or (vals == 0).all():\\n            rows.append({\\\"game\\\": game, \\\"feature\\\": feat,\\n                         \\\"n\\\": len(vals),\\n                         \\\"t25\\\": \\\"N/A\\\", \\\"t50\\\": \\\"N/A\\\", \\\"t75\\\": \\\"N/A\\\",\\n                         \\\"Q1(≤t25)\\\": \\\"N/A\\\", \\\"Q2(t25<x≤t50)\\\": \\\"N/A\\\",\\n                         \\\"Q3(t50<x≤t75)\\\": \\\"N/A\\\", \\\"Q4(>t75)\\\": \\\"N/A\\\"})\\n            continue\\n\\n        raw25, raw50, raw75 = np.percentile(vals, [25, 50, 75])\\n        t25, t50, t75 = to_n5(raw25), to_n5(raw50), to_n5(raw75)\\n\\n        # threshold가 겹치는 경우 유니크하게 처리\\n        thresholds = sorted(set([t25, t50, t75]))\\n        bins = [-np.inf] + thresholds + [np.inf]\\n        counts, _ = np.histogram(vals, bins=bins)\\n        props = counts / len(vals)\\n\\n        # 4구간 레이블 (threshold 중복 시 구간이 3개 이하일 수 있음)\\n        labels = []\\n        for i in range(len(bins) - 1):\\n            lo = f\\\"{bins[i]:.1f}\\\" if np.isfinite(bins[i]) else \\\"-∞\\\"\\n            hi = f\\\"{bins[i+1]:.1f}\\\" if np.isfinite(bins[i+1]) else \\\"+∞\\\"\\n            labels.append(f\\\"({lo}, {hi}]\\\")\\n\\n        # 항상 4개 컬럼으로 맞추기 (중복 threshold → 빈 컬럼)\\n        prop_q = [f\\\"{p*100:.1f}%\\\" for p in props]\\n        while len(prop_q) < 4:\\n            prop_q.append(\\\"—\\\")\\n\\n        rows.append({\\n            \\\"game\\\":           game,\\n            \\\"feature\\\":        feat,\\n            \\\"n\\\":              len(vals),\\n            \\\"raw_p25→t25\\\":    f\\\"{raw25:.1f}→{t25:.1f}\\\",\\n            \\\"raw_p50→t50\\\":    f\\\"{raw50:.1f}→{t50:.1f}\\\",\\n            \\\"raw_p75→t75\\\":    f\\\"{raw75:.1f}→{t75:.1f}\\\",\\n            \\\"Q1\\\":             prop_q[0],\\n            \\\"Q2\\\":             prop_q[1],\\n            \\\"Q3\\\":             prop_q[2],\\n            \\\"Q4\\\":             prop_q[3],\\n        })\\n\\nresult_df = pd.DataFrame(rows)\\n\\n# 게임별로 출력\\nfor game in GAMES:\\n    print(f\\\"\\\\n{'='*70}\\\")\\n    print(f\\\"  {game.upper()}\\\")\\n    print(f\\\"{'='*70}\\\")\\n    sub = result_df[result_df[\\\"game\\\"] == game].drop(columns=\\\"game\\\")\\n    display(sub.set_index(\\\"feature\\\"))\\n\"\n",
    "   ],\n",
    "   \"id\": \"f96354d1a5c017e3\"\n",
