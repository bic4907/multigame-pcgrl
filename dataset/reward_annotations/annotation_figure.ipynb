    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"qdmtxluj8wb\",\n",
    "   \"source\": [\n",
    "    \"from scipy.stats import gaussian_kde\\n\",\n",
    "    \"\\n\",\n",
    "    \"n_games   = len(GAMES)\\n\",\n",
    "    \"n_rewards = len(REWARDS)\\n\",\n",
    "    \"\\n\",\n",
    "    \"fig, axes = plt.subplots(\\n\",\n",
    "    \"    n_rewards, n_games,\\n\",\n",
    "    \"    figsize=(4 * n_games, 3.0 * n_rewards),\\n\",\n",
    "    \"    sharey=\\\"row\\\",\\n\",\n",
    "    \")\\n\",\n",
    "    \"fig.suptitle(\\\"Reward Condition KDE Distribution by Game (Lineplot)\\\", fontsize=16, fontweight=\\\"bold\\\", y=1.01)\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _is_empty(vals):\\n\",\n",
    "    \"    \\\"\\\"\\\"데이터 없음 또는 모두 0인 경우 True.\\\"\\\"\\\"\\n\",\n",
    "    \"    return len(vals) == 0 or (vals == 0).all()\\n\",\n",
    "    \"\\n\",\n",
    "    \"for row_i, (r_enum, feat, cond_col) in enumerate(REWARDS):\\n\",\n",
    "    \"    sub = all_df[all_df[\\\"feature_name\\\"] == feat]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # N/A가 아닌 게임들의 값(0 포함)으로 x 범위 계산\\n\",\n",
    "    \"    valid_vals = []\\n\",\n",
    "    \"    for game in GAMES:\\n\",\n",
    "    \"        v = pd.to_numeric(sub[sub[\\\"game\\\"] == game][cond_col], errors=\\\"coerce\\\").dropna().values\\n\",\n",
    "    \"        if not _is_empty(v):\\n\",\n",
    "    \"            valid_vals.append(v)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if not valid_vals:\\n\",\n",
    "    \"        for col_j in range(n_games):\\n\",\n",
    "    \"            axes[row_i, col_j].axis(\\\"off\\\")\\n\",\n",
    "    \"        continue\\n\",\n",
    "    \"\\n\",\n",
    "    \"    combined = np.concatenate(valid_vals)\\n\",\n",
    "    \"    x_min, x_max = combined.min(), combined.max()\\n\",\n",
    "    \"    x_pad = (x_max - x_min) * 0.05 if x_max > x_min else 1.0\\n\",\n",
    "    \"    x_grid = np.linspace(x_min - x_pad, x_max + x_pad, 300)\\n\",\n",
    "    \"    dx = x_grid[1] - x_grid[0]  # density → ratio 변환용\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for col_j, game in enumerate(GAMES):\\n\",\n",
    "    \"        ax = axes[row_i, col_j]\\n\",\n",
    "    \"        vals = pd.to_numeric(\\n\",\n",
    "    \"            sub[sub[\\\"game\\\"] == game][cond_col], errors=\\\"coerce\\\"\\n\",\n",
    "    \"        ).dropna().values\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if _is_empty(vals):\\n\",\n",
    "    \"            ax.text(0.5, 0.5, \\\"N/A\\\", ha=\\\"center\\\", va=\\\"center\\\",\\n\",\n",
    "    \"                    transform=ax.transAxes, color=\\\"gray\\\", fontsize=9)\\n\",\n",
    "    \"            ax.set_xlim(x_min - x_pad, x_max + x_pad)\\n\",\n",
    "    \"        elif vals.std() > 0:\\n\",\n",
    "    \"            kde = gaussian_kde(vals, bw_method=\\\"scott\\\")\\n\",\n",
    "    \"            y = kde(x_grid) * dx  # density * dx = 각 grid cell 범위의 데이터 비율\\n\",\n",
    "    \"            ax.plot(x_grid, y, color=GAME_COLORS[game], linewidth=2)\\n\",\n",
    "    \"            ax.fill_between(x_grid, y, alpha=0.25, color=GAME_COLORS[game])\\n\",\n",
    "    \"            ax.set_xlim(x_min - x_pad, x_max + x_pad)\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            ax.axvline(vals.mean(), color=GAME_COLORS[game], linewidth=2)\\n\",\n",
    "    \"            ax.set_xlim(x_min - x_pad, x_max + x_pad)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        ax.grid(axis=\\\"both\\\", linestyle=\\\"--\\\", alpha=0.4)\\n\",\n",
    "    \"        if col_j == 0:\\n\",\n",
    "    \"            ax.set_ylabel(f\\\"R{r_enum}: {feat}\\\\nRatio\\\", fontsize=8)\\n\",\n",
    "    \"        if row_i == 0:\\n\",\n",
    "    \"            ax.set_title(game, fontsize=11, fontweight=\\\"bold\\\", color=GAME_COLORS[game])\\n\",\n",
    "    \"        if row_i == n_rewards - 1:\\n\",\n",
    "    \"            ax.set_xlabel(f\\\"{cond_col}\\\\n(y = ratio per grid cell)\\\", fontsize=8)\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"#plt.savefig(\\\"lineplot_rewards_kde.png\\\", dpi=150, bbox_inches=\\\"tight\\\")\\n\",\n",
    "    \"plt.show()\"\n",
    "   ],\n",
