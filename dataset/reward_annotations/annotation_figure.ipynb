    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"l6undaell7\",\n",
    "   \"source\": [\n",
    "    \"# Lineplot (smoothing 없음) — 행=game, 열=reward, 같은 reward(열)는 y-scale 통일\\n\",\n",
    "    \"n_games   = len(GAMES)\\n\",\n",
    "    \"n_rewards = len(REWARDS)\\n\",\n",
    "    \"\\n\",\n",
    "    \"fig, axes = plt.subplots(\\n\",\n",
    "    \"    n_games, n_rewards,\\n\",\n",
    "    \"    figsize=(4 * n_rewards, 3.0 * n_games),\\n\",\n",
    "    \"    sharey=\\\"col\\\",\\n\",\n",
    "    \")\\n\",\n",
    "    \"fig.suptitle(\\\"Reward Condition Distribution by Game (No Smoothing)\\\", fontsize=16, fontweight=\\\"bold\\\", y=1.01)\\n\",\n",
    "    \"\\n\",\n",
    "    \"N_BINS = 30\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _is_empty(vals):\\n\",\n",
    "    \"    \\\"\\\"\\\"데이터 없음 또는 모두 0인 경우 True.\\\"\\\"\\\"\\n\",\n",
    "    \"    return len(vals) == 0 or (vals == 0).all()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# reward별 x 범위: N/A가 아닌 게임들의 값(0 포함)으로 계산\\n\",\n",
    "    \"reward_ranges = {}\\n\",\n",
    "    \"for r_enum, feat, cond_col in REWARDS:\\n\",\n",
    "    \"    sub = all_df[all_df[\\\"feature_name\\\"] == feat]\\n\",\n",
    "    \"    valid_vals = []\\n\",\n",
    "    \"    for game in GAMES:\\n\",\n",
    "    \"        v = pd.to_numeric(sub[sub[\\\"game\\\"] == game][cond_col], errors=\\\"coerce\\\").dropna().values\\n\",\n",
    "    \"        if not _is_empty(v):\\n\",\n",
    "    \"            valid_vals.append(v)\\n\",\n",
    "    \"    if valid_vals:\\n\",\n",
    "    \"        combined = np.concatenate(valid_vals)\\n\",\n",
    "    \"        vmin, vmax = combined.min(), combined.max()\\n\",\n",
    "    \"        reward_ranges[feat] = (vmin, vmax) if vmax > vmin else (vmin - 1, vmax + 1)\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        reward_ranges[feat] = (0.0, 1.0)\\n\",\n",
    "    \"\\n\",\n",
    "    \"for col_j, (r_enum, feat, cond_col) in enumerate(REWARDS):\\n\",\n",
    "    \"    x_min, x_max = reward_ranges[feat]\\n\",\n",
    "    \"    x_pad = (x_max - x_min) * 0.05 if x_max > x_min else 1.0\\n\",\n",
    "    \"    bins  = np.linspace(x_min, x_max, N_BINS + 1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    sub = all_df[all_df[\\\"feature_name\\\"] == feat]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for row_i, game in enumerate(GAMES):\\n\",\n",
    "    \"        ax = axes[row_i, col_j]\\n\",\n",
    "    \"        vals = pd.to_numeric(\\n\",\n",
    "    \"            sub[sub[\\\"game\\\"] == game][cond_col], errors=\\\"coerce\\\"\\n\",\n",
    "    \"        ).dropna().values\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if _is_empty(vals):\\n\",\n",
    "    \"            ax.text(0.5, 0.5, \\\"N/A\\\", ha=\\\"center\\\", va=\\\"center\\\",\\n\",\n",
    "    \"                    transform=ax.transAxes, color=\\\"gray\\\", fontsize=9)\\n\",\n",
    "    \"            ax.set_xlim(x_min - x_pad, x_max + x_pad)\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            counts, edges = np.histogram(vals, bins=bins, density=False)\\n\",\n",
    "    \"            ratio = counts / len(vals)  # 전체 데이터 중 각 bin의 비율 (0값 포함)\\n\",\n",
    "    \"            x_step = np.append(edges[:-1], edges[-1])\\n\",\n",
    "    \"            y_step = np.append(ratio, 0)\\n\",\n",
    "    \"            ax.step(x_step, y_step, where=\\\"post\\\",\\n\",\n",
    "    \"                    color=GAME_COLORS[game], linewidth=2)\\n\",\n",
    "    \"            ax.fill_between(x_step, y_step, step=\\\"post\\\",\\n\",\n",
    "    \"                            alpha=0.25, color=GAME_COLORS[game])\\n\",\n",
    "    \"            ax.set_xlim(x_min - x_pad, x_max + x_pad)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        ax.grid(axis=\\\"both\\\", linestyle=\\\"--\\\", alpha=0.4)\\n\",\n",
    "    \"        if col_j == 0:\\n\",\n",
    "    \"            ax.set_ylabel(game, fontsize=10, fontweight=\\\"bold\\\", color=GAME_COLORS[game])\\n\",\n",
    "    \"        if row_i == 0:\\n\",\n",
    "    \"            ax.set_title(f\\\"R{r_enum}: {feat}\\\", fontsize=10, fontweight=\\\"bold\\\")\\n\",\n",
    "    \"        if row_i == n_games - 1:\\n\",\n",
    "    \"            ax.set_xlabel(f\\\"{cond_col}\\\\n(y = ratio per bin)\\\", fontsize=8)\\n\",\n",
    "    \"\\n\",\n",
